{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "database": {
    "rules": "database-rules.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  }
}
